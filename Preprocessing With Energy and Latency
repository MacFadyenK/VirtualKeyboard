data = load('/Users/nickh/Downloads/s17.mat');

t2 = data.train{1};

samplingrate = t2.srate;

baseline_samples = round(0.2 * samplingrate);
epoch_samples = round(0.6 * samplingrate);

[b,a] = butter(4, [0.5 15]/(samplingrate/2), 'bandpass');

selected_channels = [31 32 12 13 19 14 18 16];
time = (0:epoch_samples-1)/samplingrate * 1000;

raw_data = t2.data(selected_channels,:);

flash_indices = find(t2.markers_seq >= 1 & t2.markers_seq <= 12);
flash_ids = t2.markers_seq(flash_indices);

flash_indices = find(t2.markers_seq >= 1 & t2.markers_seq <= 12);
flash_ids = t2.markers_seq(flash_indices);

all_epochs = [];
all_flash_ids = [];

energy_per_flop = 5.6e-12;  % Joules per FLOP
total_flops = 0; % Intitializes total FLOP counter

tic; % start latency timing

for i = 1:length(flash_indices)

    stim = flash_indices(i);

    if stim-baseline_samples > 0 && stim+epoch_samples-1 <= size(raw_data,2)

        baseline = mean(raw_data(:, stim-baseline_samples:stim),2);
        flops_baseline = numel(raw_data(:, stim-baseline_samples:stim)); %Counts the number of FLOPs in the baseline segment

        epoch = raw_data(:, stim:stim+epoch_samples-1);
        flops_epoch = numel(epoch); %Counts the number of FLOPs in epoch
        epoch = epoch - baseline;

        epoch = detrend(epoch')';
        flops_detrend = 2 * numel(epoch); %Counts # of FLOPs for detrending by assuming 2 floating-point operations per element

        epoch = filtfilt(b,a,epoch')';
        flops_filter = 4 * numel(epoch) * length(b); %# of FLOPs by assuming roughly 4 floating-point operations per element
    
        total_flops = total_flops + flops_baseline + flops_epoch + flops_detrend + flops_filter; %Equation to get toal FLOPs for preprocessing

        all_epochs(:,:,i) = epoch;
        all_flash_ids(i) = flash_ids(i);

    end
end

elapsed_time = toc; % end latency timing


energy_total = total_flops * energy_per_flop;  % Joules - Equation to calculate energy from # of FLOPs


save('/Users/nickh/Downloads/S17_FlashEpochs_Preprocessing_MATLAB.mat', ...
    'all_epochs','all_flash_ids','time');


disp('Dataset is processed and stored!');
fprintf('LATENCY: %.6f sec\n', elapsed_time);
fprintf('Total FLOPs: %.3e\n', total_flops);
fprintf('Estimated Energy: %.6f J\n', energy_total);


% Be sure to have Signal Processing Toolbox installed to run this code. 
% This code counts the number of FLOPs per section of the preprocessing
% Essentially all it is, similar to latency, just sets a counter on each
% step of the process and adds up the number of FLOPs per section and that
% is how you get the total FLOPs for the whole code.  The latency is just a
% timer for the preprocessing to show how long the system take to run the
% code.  There are 4 parts to calculating out the FLOPs for the
% preprocessing, baseline, epoch, filtering, and detrending, as those are
% the 4 components of the preprocessing.  For the baseline and the epoch,
% it is simply just counting the number of FLOPs by taking the selected
% channels and multipling by the number of baseline samples, which is the
% FLOPs value.  This is done in the previous section so we can just use
% numel  to count. Same concept for the epoch, number of selected channels
% times the number of epoch samples, FLOPs.  For the detrending its the
% same concept as the epoch, except this time the count gets multiplied by
% two as this is an estimate of 2 floating-point opration per element for
% the detrending.  We use 2 as the average because it is a reasonable
% estimation for the varient different counting components in the detrending.  
% Similary we use 4 when calucating out the FLOPs for filtering.  4 accounts for the 
% forward and backward passes in the filtfilt operation, effectively
% doubling the operations for the zero-phase filtering.  The difference 
% here is you are also multipling length(b) into the count because it 
% represent the number of coefficients in the filter, and each coefficient 
% is used in a multiply-and-add operation for every data point.  So, for 
% each sample in the signal the CPU must preform one multiply and one add 
% per coefficient, which directly scales to the total number of FLOPs. 
% Without it, the FLOP estimate would simply ignoe the compuational effort 
% required be longer filters.  With all of this we use the Total FLOPs as
% the addition of all the compontents, to give us the total FLOPs of the
% preprocessing.  To convert the number of FLOPs to how much power/energy,
% you take the total FLOPs and multiply it by the energy per FLOP
% estimation of 5.6 pJ.  The Latency timer is also stopped at the end of
% the code to show the time it takes to run the preprocessing.  Each of
% these components are then displayed in the command window as the final
% measurement of the preprocessing.
